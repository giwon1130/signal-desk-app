# ── Signal Desk 웹 정적 사이트 (Railway 전용) ───────────────────────────────
#
# Expo 웹 번들을 빌드한 뒤 nginx:alpine 으로 호스팅.
# 이전 `serve@14` (Node 런타임) 대비 메모리 ~70MB → ~10MB, throughput 빠름.
# Railway 메모리 청구 ↓ + 콜드 스타트 ↓ + 정적 자산 캐싱 헤더 + gzip.
#
# Railway 가 주입하는 $PORT 는 nginx 의 envsubst 가 templates 에서 자동 치환.

FROM node:20-slim AS builder
WORKDIR /app

# 네이티브 컴파일이 필요한 패키지 대비 최소 빌드 도구
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts --no-audit --no-fund

COPY . .
# 서버 URL 은 빌드 시점에 번들에 박힘. 기본값 프로덕션 Railway API.
ARG EXPO_PUBLIC_API_BASE_URL=https://signal-desk-api-production.up.railway.app
ENV EXPO_PUBLIC_API_BASE_URL=$EXPO_PUBLIC_API_BASE_URL

RUN npx expo export --platform web --output-dir dist

# ── Runtime: nginx:alpine ───────────────────────────────────────────────────
FROM nginx:alpine

# 기본 default.conf 제거하고 PORT 치환되는 template 로 교체
RUN rm /etc/nginx/conf.d/default.conf
COPY docker/nginx-web.conf.template /etc/nginx/templates/default.conf.template

COPY --from=builder /app/dist /usr/share/nginx/html

# Privacy Policy 정적 페이지 (App Store 필수 URL).
# /privacy 또는 /privacy.html 둘 다 같은 파일 (nginx try_files 처리).
COPY docker/privacy.html /usr/share/nginx/html/privacy.html

ENV PORT=3000
EXPOSE 3000

# nginx:alpine 은 /etc/nginx/templates/*.template → /etc/nginx/conf.d/* 자동 envsubst
CMD ["nginx", "-g", "daemon off;"]
