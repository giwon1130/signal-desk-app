{
  "expo": {
    "name": "signal-desk-app",
    "slug": "signal-desk-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.giwon.signaldesk",
      "usesAppleSignIn": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "장 시작과 단타 픽 업데이트 시점을 알려드려요.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Signal Desk — 투자 대시보드",
      "shortName": "Signal Desk",
      "description": "시장/종목/단타 시그널을 한눈에 보는 개인 투자 대시보드",
      "themeColor": "#0a1628",
      "backgroundColor": "#0a1628"
    },
    "scheme": "signaldesk",
    "experiments": {
      "baseUrl": "/signal-desk-app"
    },
    "extra": {
      "googleClientIdIos": "496073748220-n9end3a963hj96nh6ru6ai3d54u8g72v.apps.googleusercontent.com",
      "googleClientIdAndroid": "",
      "googleClientIdWeb": "496073748220-lvagt9ir98pc3qc2lfqtglqbjem4ed2c.apps.googleusercontent.com",
      "eas": {
        "projectId": "891d142e-d493-43d3-a7b1-ac7bdcf23963"
      }
    },
    "plugins": [
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0a1628",
          "sounds": []
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.496073748220-n9end3a963hj96nh6ru6ai3d54u8g72v"
        }
      ]
    ],
    "owner": "giwon1130"
  }
}
