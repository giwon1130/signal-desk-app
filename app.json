{
  "expo": {
    "name": "signal-desk-app",
    "slug": "signal-desk-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.signal-desk-app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "장 시작과 단타 픽 업데이트 시점을 알려드려요."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Signal Desk — 투자 대시보드",
      "shortName": "Signal Desk",
      "description": "시장/종목/단타 시그널을 한눈에 보는 개인 투자 대시보드",
      "themeColor": "#0a1628",
      "backgroundColor": "#0a1628"
    },
    "scheme": "signaldesk",
    "extra": {
      "googleClientIdIos": "496073748220-f8me1jt6oiedqq6a7lfmvhjhnu2lh2j1.apps.googleusercontent.com",
      "googleClientIdAndroid": "",
      "googleClientIdWeb": "496073748220-oavb78f6holdrlhlvqa6b1fcljih1g4u.apps.googleusercontent.com"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0a1628",
          "sounds": []
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.496073748220-f8me1jt6oiedqq6a7lfmvhjhnu2lh2j1"
        }
      ]
    ]
  }
}
